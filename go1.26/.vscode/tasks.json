{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "go build",
      "type": "shell",
      "command": "go",
      "args": ["build", "."],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$go"
    },
    {
      "label": "go vet",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "problemMatcher": "$go"
    },
    {
      "label": "go test",
      "type": "shell",
      "command": "go",
      "args": ["test", "-v", "./..."],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$go"
    }
  ]
}
